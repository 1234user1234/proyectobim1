<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.proyectobim1.ui.fragment.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_carList"
            app:destination="@id/carListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/carListFragment"
        android:name="com.example.proyectobim1.ui.fragment.CarListFragment"
        android:label="Mis Vehículos"
        tools:layout="@layout/fragment_car_list">
        <action
            android:id="@+id/action_carList_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_carList_to_detail"
            app:destination="@id/carDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.proyectobim1.ui.fragment.RegisterFragment"
        android:label="Registrar Vehículo"
        tools:layout="@layout/fragment_register" />

    <fragment
        android:id="@+id/carDetailFragment"
        android:name="com.example.proyectobim1.ui.fragment.CarDetailFragment"
        android:label="Detalle del Vehículo"
        tools:layout="@layout/fragment_car_detail"/>



</navigation>